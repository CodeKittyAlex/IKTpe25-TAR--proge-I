@model IEnumerable<University.ViewModle.StudentIndexViewModle>

@{
    ViewData["Title"] = "Student Index";
}

<h2>Student Index</h2>

<p>
    <a asp-action="Create">Create New</a>
</p>

<h4>Student</h4>
<hr />

<table class="table">
    <thead>
        <tr>
            <th class="col-sm-10">
                @Html.DisplayNameFor(Model => Model.LastName)
            </th>
            <th class="col-sm-10">
                @Html.DisplayNameFor(Model => Model.FirstMidName)
            </th>
            <th class="col-sm-10">
                @Html.DisplayNameFor(Model => Model.EnrollmentDate)
            </th>
        </tr>
    </thead>

    <Tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="col-sm-10">
                    @Html.DisplayFor(Model => item.LastName)
                </td>
                <td class="col-sm-10">
                    @Html.DisplayFor(Model => item.FirstMidName)
                </td>
                <td class="col-sm-10">
                    @Html.DisplayFor(Model => item.EnrollmentDate)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    <a asp-action="Detail" asp-route-id="@item.Id">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr> 
        }
    </Tbody>
</table>
